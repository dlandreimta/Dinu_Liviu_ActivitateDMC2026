<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <Button
        android:id="@+id/dlbtnFilterBucuresti"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Evenimente Bucuresti" />

    <Button
        android:id="@+id/dlbtnTwo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sterge Evenimente 2025" />

    <Button
        android:id="@+id/dlbtnThree"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Modifica Data Eveniment" />

    <ListView
        android:id="@+id/dllvFiltered"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp" />

</LinearLayout>