<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/add_root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDFDFD">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E0E0E0"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvConfigTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/config_title"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#1A1C1E"
                    android:layout_marginBottom="24dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_model"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="16dp"
                    app:hintTextColor="#44474E">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etModel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#1A1C1E"
                        android:textColorHint="#44474E" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_ram"
                    android:textStyle="bold"
                    android:textColor="#44474E"
                    android:layout_marginBottom="8dp"/>
                <Spinner
                    android:id="@+id/spRam"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp"
                    android:background="@android:drawable/btn_dropdown"/>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/cbKeyboard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_keyboard"
                    android:textColor="#1A1C1E"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_screen"
                    android:textStyle="bold"
                    android:textColor="#44474E"
                    android:layout_marginBottom="8dp"/>
                <RadioGroup
                    android:id="@+id/rgScreenType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">
                    <RadioButton android:id="@+id/rbLcd" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/screen_lcd" android:textColor="#1A1C1E" android:layout_marginEnd="16dp"/>
                    <RadioButton android:id="@+id/rbOled" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/screen_oled" android:textColor="#1A1C1E" android:layout_marginEnd="16dp"/>
                    <RadioButton android:id="@+id/rbAmoled" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/screen_amoled" android:textColor="#1A1C1E"/>
                </RadioGroup>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_date"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="16dp"
                    app:hintTextColor="#44474E">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="true"
                        android:clickable="true"
                        android:textColor="#1A1C1E"
                        android:textColorHint="#44474E" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_rating"
                    android:textStyle="bold"
                    android:textColor="#44474E"
                    android:layout_gravity="center_horizontal"/>
                <RatingBar
                    android:id="@+id/rbPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:numStars="5"
                    android:stepSize="1"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="24dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/btn_save"
                    app:cornerRadius="12dp"
                    android:textStyle="bold"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>